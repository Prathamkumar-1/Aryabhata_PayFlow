# ============================================================================
# PayFlow — .gitignore
# ============================================================================

# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
dist/
build/
*.egg
.pytest_cache/
.mypy_cache/

# Virtual environment
.venv/
venv/
env/

# IDE
.vscode/
!.vscode/settings.json
.idea/
*.swp
*.swo

# OS
Thumbs.db
Desktop.ini
.DS_Store

# Data (too large for git — use DVC or cloud storage)
data/raw/*
data/processed/*
data/synthetic/*
data/*.db
data/*.db-shm
data/*.db-wal
*.mp4
!data/**/.gitkeep

# Artifacts
artifacts/models/*
artifacts/evidence/*
artifacts/reports/*
artifacts/*.err.log
artifacts/*.out.log
artifacts/*.log
artifacts/*.png
artifacts/smoke/
frontend/app/artifacts/
frontend/app/test-results/
!artifacts/**/.gitkeep
!docs/assets/**
logs/*
!logs/.gitkeep

# Environment
.env
.env.local
*.pem
*.key

# PyTorch / ML
*.pt
*.pth
*.onnx
*.bin
checkpoints/

# Jupyter
.ipynb_checkpoints/

# Vite cache
.vite/

# Frontend
frontend/app/node_modules/
frontend/app/dist/
frontend/app/.vite/
